+/* Servers older than 0.3.72 only announce a port mix via port_set_mix_info
+ * from their set_io path, which arrives AFTER port_use_buffers/port_set_io;
+ * newer clients dropped the on-demand mix creation older clients had, so
+ * every stream against such a server fails with use_buffers() -ENOENT and
+ * the node never starts. Restore the old tolerance: create the mix on
+ * demand (peer unknown until the server tells us). */
+static struct mix *ensure_mix(struct node_data *data,
+		enum spa_direction direction, uint32_t port_id, uint32_t mix_id)
+{
+	struct mix *mix;
+	struct pw_impl_port *port;
+
+	if ((mix = find_mix(data, direction, port_id, mix_id)))
+		return mix;
+	port = pw_impl_node_find_port(data->node, direction, port_id);
+	if (port == NULL)
+		return NULL;
+	return create_mix(data, port, mix_id, SPA_ID_INVALID);
+}
